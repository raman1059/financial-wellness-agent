# ─── App ─────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# Optional for local demo — a fallback secret is hardcoded in auth.config.ts.
# Required in production: openssl rand -base64 32
NEXTAUTH_SECRET=

# ─── AI ───────────────────────────────────────────────────────────────────────
# Optional for local demo — omitting this enables mock AI responses.
# Required for live Claude answers: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ─── Database ─────────────────────────────────────────────────────────────────
# Not required for local demo — all data is served from mock-data.ts.
# Required when switching to a real database:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/financial_wellness
# DIRECT_URL=postgresql://postgres:password@localhost:5432/financial_wellness

# ─── OAuth (optional) ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Supabase (optional) ──────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Redis (optional — rate limiting) ─────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Storage (optional) ───────────────────────────────────────────────────────
STORAGE_BUCKET=payslips

# ─── Encryption (optional) ────────────────────────────────────────────────────
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FIELD_ENCRYPTION_KEY=

# ─── Email (optional) ─────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─── Background Jobs (optional) ───────────────────────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
