generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  USER
  ACCOUNTANT
}

enum EmploymentType {
  SALARIED
  SELF_EMPLOYED
  CONTRACT
  FREELANCE
}

enum TaxRegime {
  OLD
  NEW
}

enum PayslipStatus {
  PENDING
  PROCESSING
  PARSED
  VERIFIED
  FAILED
}

enum InvestmentProofType {
  PPF_STATEMENT
  ELSS_STATEMENT
  LIFE_INSURANCE_PREMIUM
  HEALTH_INSURANCE_PREMIUM
  HOME_LOAN_STATEMENT
  NSC_CERTIFICATE
  NPS_STATEMENT
  RENT_RECEIPT
  TUITION_FEE_RECEIPT
  OTHER
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_RESUBMISSION
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum AuditAction {
  USER_LOGIN
  USER_LOGOUT
  USER_REGISTER
  PASSWORD_CHANGED
  MFA_ENABLED
  MFA_DISABLED
  SESSION_REVOKED
  OAUTH_LINKED
  RECORD_CREATED
  RECORD_UPDATED
  RECORD_DELETED
  RECORD_VIEWED
  DOCUMENT_UPLOADED
  DOCUMENT_DOWNLOADED
  DOCUMENT_DELETED
  OCR_COMPLETED
  OCR_FAILED
  PROOF_SUBMITTED
  PROOF_VERIFIED
  PROOF_REJECTED
  AI_SESSION_STARTED
  AI_SESSION_CLOSED
  AI_MESSAGE_SENT
  AI_RESPONSE_GENERATED
  TAX_DECLARATION_CREATED
  TAX_DECLARATION_SUBMITTED
  TAX_ESTIMATE_GENERATED
  TAX_REGIME_CHANGED
  UNAUTHORIZED_ACCESS_ATTEMPT
  RATE_LIMIT_EXCEEDED
  PERMISSION_DENIED
  SUSPICIOUS_ACTIVITY
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?
  role          UserRole  @default(USER)
  mfaEnabled    Boolean   @default(false)
  mfaSecret     Bytes?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  employee       Employee?
  chatSessions   ChatSession[]
  auditLogs      AuditLog[]    @relation("AffectedUser")
  actorAuditLogs AuditLog[]    @relation("ActorUser")

  @@index([email])
  @@index([role])
  @@index([deletedAt])
  @@map("users")
}

// ─── Employee ─────────────────────────────────────────────────────────────────

model Employee {
  id             String         @id @default(cuid())
  userId         String         @unique
  employeeCode   String?
  designation    String?
  department     String?
  employmentType EmploymentType @default(SALARIED)
  employerName   String?
  employerPan    Bytes?
  employerTan    Bytes?
  panNumber      Bytes?
  aadhaarLast4   String?
  dateOfBirth    DateTime?
  dateOfJoining  DateTime?
  dateOfLeaving  DateTime?
  residentialState String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  payrollRecords  PayrollRecord[]
  payslips        Payslip[]
  taxDeclarations TaxDeclaration[]

  @@map("employees")
}

// ─── PayrollRecord ────────────────────────────────────────────────────────────

model PayrollRecord {
  id               String   @id @default(cuid())
  employeeId       String
  userId           String
  payPeriodMonth   Int
  payPeriodYear    Int
  basicSalary      Decimal  @db.Decimal(14, 2)
  hra              Decimal  @db.Decimal(14, 2) @default(0)
  specialAllowance Decimal  @db.Decimal(14, 2) @default(0)
  lta              Decimal  @db.Decimal(14, 2) @default(0)
  medicalAllowance Decimal  @db.Decimal(14, 2) @default(0)
  otherEarnings    Decimal  @db.Decimal(14, 2) @default(0)
  grossSalary      Decimal  @db.Decimal(14, 2)
  providentFund    Decimal  @db.Decimal(14, 2) @default(0)
  professionalTax  Decimal  @db.Decimal(14, 2) @default(0)
  tdsDeducted      Decimal  @db.Decimal(14, 2) @default(0)
  esic             Decimal  @db.Decimal(14, 2) @default(0)
  otherDeductions  Decimal  @db.Decimal(14, 2) @default(0)
  totalDeductions  Decimal  @db.Decimal(14, 2)
  netSalary        Decimal  @db.Decimal(14, 2)
  payslipId        String?
  isVerified       Boolean  @default(false)
  verifiedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  employee Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payslip  Payslip?  @relation(fields: [payslipId], references: [id], onDelete: SetNull)

  @@unique([employeeId, payPeriodMonth, payPeriodYear])
  @@index([userId])
  @@index([employeeId])
  @@index([payPeriodYear, payPeriodMonth])
  @@map("payroll_records")
}

// ─── Payslip ──────────────────────────────────────────────────────────────────

model Payslip {
  id             String        @id @default(cuid())
  employeeId     String
  userId         String
  fileName       String
  fileKey        String
  fileMimeType   String
  fileSizeBytes  Int
  fileHash       String
  status         PayslipStatus @default(PENDING)
  ocrProvider    String?
  ocrConfidence  Float?
  ocrRawText     String?       @db.Text
  parsedFields   Json?
  parseErrors    Json?
  payPeriodMonth Int?
  payPeriodYear  Int?
  processedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  employee       Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payrollRecords PayrollRecord[]

  @@index([userId])
  @@index([employeeId])
  @@index([status])
  @@index([fileHash])
  @@map("payslips")
}

// ─── TaxDeclaration ───────────────────────────────────────────────────────────

model TaxDeclaration {
  id                    String    @id @default(cuid())
  employeeId            String
  userId                String
  financialYear         String    @db.VarChar(7)
  taxRegime             TaxRegime @default(NEW)
  ppfAmount             Decimal   @db.Decimal(12, 2) @default(0)
  elssAmount            Decimal   @db.Decimal(12, 2) @default(0)
  lifeInsurance         Decimal   @db.Decimal(12, 2) @default(0)
  homeLoanPrincipal     Decimal   @db.Decimal(12, 2) @default(0)
  nscAmount             Decimal   @db.Decimal(12, 2) @default(0)
  tuitionFees           Decimal   @db.Decimal(12, 2) @default(0)
  other80C              Decimal   @db.Decimal(12, 2) @default(0)
  total80C              Decimal   @db.Decimal(12, 2) @default(0)
  selfHealthInsurance   Decimal   @db.Decimal(12, 2) @default(0)
  parentHealthInsurance Decimal   @db.Decimal(12, 2) @default(0)
  hraReceived           Decimal   @db.Decimal(12, 2) @default(0)
  hraExempt             Decimal   @db.Decimal(12, 2) @default(0)
  npsContribution       Decimal   @db.Decimal(12, 2) @default(0)
  homeLoanInterest      Decimal   @db.Decimal(12, 2) @default(0)
  educationLoanInterest Decimal   @db.Decimal(12, 2) @default(0)
  grossIncome           Decimal   @db.Decimal(14, 2) @default(0)
  standardDeduction     Decimal   @db.Decimal(12, 2) @default(0)
  totalDeductions       Decimal   @db.Decimal(14, 2) @default(0)
  taxableIncome         Decimal   @db.Decimal(14, 2) @default(0)
  estimatedTaxLiability Decimal   @db.Decimal(14, 2) @default(0)
  totalTdsPaid          Decimal   @db.Decimal(14, 2) @default(0)
  taxPayable            Decimal   @db.Decimal(14, 2) @default(0)
  isSubmitted           Boolean   @default(false)
  submittedAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  employee         Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  investmentProofs InvestmentProof[]

  @@unique([employeeId, financialYear])
  @@index([userId])
  @@index([financialYear])
  @@map("tax_declarations")
}

// ─── InvestmentProof ──────────────────────────────────────────────────────────

model InvestmentProof {
  id               String              @id @default(cuid())
  taxDeclarationId String
  userId           String
  proofType        InvestmentProofType
  description      String?
  declaredAmount   Decimal             @db.Decimal(12, 2)
  verifiedAmount   Decimal?            @db.Decimal(12, 2)
  fileName         String
  fileKey          String
  fileMimeType     String
  fileSizeBytes    Int
  fileHash         String
  ocrParsedAmount  Decimal?            @db.Decimal(12, 2)
  ocrConfidence    Float?
  ocrRawText       String?             @db.Text
  status           VerificationStatus  @default(PENDING)
  rejectionReason  String?
  verifiedAt       DateTime?
  verifiedByUserId String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  taxDeclaration TaxDeclaration @relation(fields: [taxDeclarationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([taxDeclarationId])
  @@index([status])
  @@map("investment_proofs")
}

// ─── ChatSession ──────────────────────────────────────────────────────────────

model ChatSession {
  id                String    @id @default(cuid())
  userId            String
  title             String?
  isActive          Boolean   @default(true)
  contextPayload    Json?
  totalInputTokens  Int       @default(0)
  totalOutputTokens Int       @default(0)
  lastMessageAt     DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([userId])
  @@index([userId, isActive])
  @@map("chat_sessions")
}

// ─── ChatMessage ──────────────────────────────────────────────────────────────

model ChatMessage {
  id              String      @id @default(cuid())
  sessionId       String
  userId          String
  role            MessageRole
  content         String      @db.Text
  citations       Json?
  toolCalls       Json?
  toolResults     Json?
  isGrounded      Boolean     @default(false)
  confidenceScore Float?
  inputTokens     Int?
  outputTokens    Int?
  createdAt       DateTime    @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([userId])
  @@index([sessionId, createdAt])
  @@map("chat_messages")
}

// ─── AuditLog ─────────────────────────────────────────────────────────────────

model AuditLog {
  id           String      @id @default(cuid())
  userId       String?
  actorId      String?
  action       AuditAction
  resourceType String
  resourceId   String?
  metadata     Json?
  ipAddress    String?
  userAgent    String?
  requestId    String?
  success      Boolean     @default(true)
  errorCode    String?
  createdAt    DateTime    @default(now())

  affectedUser User? @relation("AffectedUser", fields: [userId], references: [id], onDelete: SetNull)
  actor        User? @relation("ActorUser", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([actorId])
  @@index([action])
  @@index([resourceType, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}
